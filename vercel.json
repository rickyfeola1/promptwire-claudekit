{
    "version": 2,
    "builds": [
        {
            "src": "promptwire-claude-toolkit.html",
            "use": "@vercel/static"
        },
        {
            "src": "subscribe.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/subscribe",
            "dest": "/subscribe.js"
        },
        {
            "src": "/(.*)",
            "dest": "/promptwire-claude-toolkit.html"
        }
    ]
}
